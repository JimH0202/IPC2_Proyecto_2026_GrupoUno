@model OrbitNet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header">
    <div>
        <h1>@Localizer["SatelliteDetail"]</h1>
        <p class="report-description">@Localizer["SatelliteDetailDescription"]</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Satellites" asp-action="Index" class="btn btn-primary">@Localizer["BackToList"]</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["BackToDashboard"]</a>
    </div>
</div>

<div class="section-card">
    <h3>@Localizer["SatelliteSummary"]</h3>
    <div class="stats-grid">
        <div class="stat-card">
            <strong>@Localizer["Name"]</strong>
            <p class="stat-value">@Model.Name</p>
        </div>
        <div class="stat-card">
            <strong>@Localizer["Orbit"]</strong>
            <p class="stat-value">@Model.OrbitId</p>
        </div>
        <div class="stat-card">
            <strong>@Localizer["Type"]</strong>
            <p class="stat-value">@Model.Type</p>
        </div>
        <div class="stat-card">
            <strong>@Localizer["Active"]</strong>
            <p class="stat-value">@(Model.IsActive ? Localizer["Yes"] : Localizer["No"])</p>
        </div>
    </div>
</div>

<div class="section-card">
    <h3>@Localizer["SatelliteActivity"]</h3>
    <div class="detail-list">
        <div>
            <dt>@Localizer["Position"]</dt>
            <dd>(@Model.X, @Model.Y)</dd>
        </div>
        <div>
            <dt>@Localizer["MessagesSent"]</dt>
            <dd>@Model.MessagesSent</dd>
        </div>
        <div>
            <dt>@Localizer["MessagesReceived"]</dt>
            <dd>@Model.MessagesReceived</dd>
        </div>
    </div>
</div>

