@model OrbitNet.Web.Models.ViewModels.UploadViewModel

<div class="page-header">
    <div>
        <h1>@Localizer["UploadResultTitle"]</h1>
    </div>
    <div class="page-actions">
        <a asp-controller="Upload" asp-action="Index" class="btn btn-primary">@Localizer["UploadAnotherFile"]</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["BackToDashboard"]</a>
    </div>
</div>

<div class="result-box @(Model.Success ? "success" : "error")">
    <h2>@Model.Message</h2>
    <p><strong>@Localizer["UploadResultFile"]</strong> @Model.FileName</p>
</div>

@if (Model.Success)
{
    <div class="section-card">
        <h3>@Localizer["UploadResultStats"]</h3>
        <div class="stats-grid">
            <div class="stat-card">
                <strong>@Localizer["UploadResultSatellitesLoaded"]</strong>
                <p class="stat-value">@Model.SatellitesLoaded</p>
            </div>
            <div class="stat-card">
                <strong>@Localizer["UploadResultAntennasLoaded"]</strong>
                <p class="stat-value">@Model.AntennasLoaded</p>
            </div>
            <div class="stat-card">
                <strong>@Localizer["UploadResultPolarOrbitsLoaded"]</strong>
                <p class="stat-value">@Model.PolarOrbitsLoaded</p>
            </div>
        </div>
    </div>
}

@if (Model.Errors?.Any() == true)
{
    <div class="section-card error-section">
        <h3>@Localizer["UploadErrorsFound"]</h3>
        <ul>
        @foreach (var error in Model.Errors)
        {
            <li>@error</li>
        }
        </ul>
    </div>
}
