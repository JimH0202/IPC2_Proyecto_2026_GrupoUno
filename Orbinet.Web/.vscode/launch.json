{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "OrbitNet North + South",
      "configurations": [
        "OrbitNet-North",
        "OrbitNet-South"
      ]
    }
  ],
  "configurations": [
    {
      "name": "OrbitNet-North",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net10.0/Orbinet.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "North",
        "HEMISPHERE": "North",
        "ASPNETCORE_URLS": "http://localhost:5000"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal"
    },
    {
      "name": "OrbitNet-South",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net10.0/Orbinet.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "South",
        "HEMISPHERE": "South",
        "ASPNETCORE_URLS": "http://localhost:5001"
      },
      "stopAtEntry": false,
      "console": "integratedTerminal"
    }
  ]
}
