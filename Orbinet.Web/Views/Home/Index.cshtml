@model OrbitNet.Web.Models.ViewModels.DashboardViewModel

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="report-description">Controla el estado de la constelación, operaciones y métricas del hemisferio.</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index", "Satellites")" class="action-card">Ver satélites</a>
        <a href="@Url.Action("Dashboard", "Simulation")" class="action-card">Ir a simulación</a>
        <a href="@Url.Action("MemoryLayout", "Reports")" class="action-card">Ver reportes</a>
    </div>
</div>

<div style="background-color: @(Model.Hemisphere == "South" ? "#e8f4f8" : "#f0e8f8"); padding: 15px; border-radius: 8px; margin-bottom: 20px; border-left: 5px solid @(Model.Hemisphere == "South" ? "#0078d4" : "#8764b8");">
    <h2 style="margin: 0; color: @(Model.Hemisphere == "South" ? "#0078d4" : "#8764b8");">
        OrbitNet - Hemisferio @Model.Hemisphere
    </h2>
    <p style="margin: 5px 0 0 0; font-size: 12px; color: #666;">
        @(Model.Hemisphere == "North" ? "Constelación del Hemisferio Norte • Puerto 5000" : "Constelación del Hemisferio Sur • Puerto 5001")
    </p>
</div>

<h3>Estado del Sistema</h3>

<hr />

<p><strong>Tick Actual:</strong> @Model.CurrentTick</p>

<p><strong>Satélites Activos:</strong> @Model.ActiveSatellites</p>

<p><strong>Satélites Inactivos:</strong> @Model.InactiveSatellites</p>

<p><strong>Mensajes Pendientes:</strong> @Model.PendingMessages</p>

<p><strong>Mensajes Procesados:</strong> @Model.ProcessedMessages</p>

<p><strong>Antenas:</strong> @Model.TotalAntennas</p>

<p><strong>Puerto:</strong> @Model.Port</p>

<p><strong>Hemisferio remoto:</strong> @Model.RemoteHemisphereUrl</p>

<p><strong>Simulación:</strong> @(Model.IsSimulationRunning ? "Activa" : "Detenida")</p>