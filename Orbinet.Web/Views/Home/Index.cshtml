@model OrbitNet.Web.Models.ViewModels.DashboardViewModel

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="report-description">Controla el estado de la constelación, operaciones y métricas del hemisferio.</p>
    </div>
    <div class="page-actions">
        <a href="@Url.Action("Index", "Satellites")" class="action-card">Ver satélites</a>
        <a href="@Url.Action("Dashboard", "Simulation")" class="action-card">Ir a simulación</a>
        <a href="@Url.Action("MemoryLayout", "Reports")" class="action-card">Ver reportes</a>
    </div>
</div>

<div class="hero-banner @(Model.Hemisphere == "South" ? "south" : "north")">
    <h2>OrbitNet - Hemisferio @Model.Hemisphere</h2>
    <p>@(Model.Hemisphere == "North" ? "Constelación del Hemisferio Norte • Puerto 5000" : "Constelación del Hemisferio Sur • Puerto 5001")</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <strong>Tick Actual</strong>
        <p class="stat-value">@Model.CurrentTick</p>
    </div>
    <div class="stat-card">
        <strong>Satélites Activos</strong>
        <p class="stat-value">@Model.ActiveSatellites</p>
    </div>
    <div class="stat-card">
        <strong>Mensajes Pendientes</strong>
        <p class="stat-value">@Model.PendingMessages</p>
    </div>
    <div class="stat-card">
        <strong>Mensajes Procesados</strong>
        <p class="stat-value">@Model.ProcessedMessages</p>
    </div>
</div>

<div class="section-card" style="margin-top: 24px;">
    <h3>Detalles del sistema</h3>
    <p>Estado de la simulación, antenas y la conexión con el hemisferio remoto.</p>
    <div class="stats-grid" style="margin-top: 18px;">
        <div class="stat-card">
            <strong>Antenas</strong>
            <p class="stat-value">@Model.TotalAntennas</p>
        </div>
        <div class="stat-card">
            <strong>Puerto</strong>
            <p class="stat-value">@Model.Port</p>
        </div>
        <div class="stat-card">
            <strong>Hemisferio remoto</strong>
            <p class="stat-value">@Model.RemoteHemisphereUrl</p>
        </div>
        <div class="stat-card">
            <strong>Simulación</strong>
            <p class="stat-value">@(Model.IsSimulationRunning ? "Activa" : "Detenida")</p>
        </div>
    </div>
</div>
