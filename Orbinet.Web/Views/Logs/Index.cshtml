@model List<OrbitNet.Web.Models.ViewModels.LogViewModel>

<h1>Registros del sistema</h1>
<table>
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Nivel</th>
            <th>Evento</th>
            <th>Detalles</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var log in Model)
    {
        <tr>
            <td>@log.Timestamp.ToString("g")</td>
            <td>@log.Level</td>
            <td>@log.Event</td>
            <td>@log.Details</td>
        </tr>
    }
    </tbody>
</table>
