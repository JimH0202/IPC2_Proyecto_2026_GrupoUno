@model OrbitNet.Web.Models.ViewModels.RelayDashboardViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["RelayTitle"];
}

<div class="page-header-row">
    <div class="header-summary">
        <h1>@Localizer["InterHemisphericCommunication"]</h1>
        <p>@Localizer["RelayOverviewDescription"]</p>
        <div class="header-controls">
            <label class="refresh-toggle">
                <input type="checkbox" id="autoRefreshToggleTop" checked />
                @Localizer["AutoRefresh"]
            </label>
            <select id="refreshIntervalTop" class="select-small">
                <option value="5000">5s</option>
                <option value="10000">10s</option>
                <option value="15000">15s</option>
            </select>
            <button id="refreshDashboardBtn" class="btn btn-primary btn-sm" type="button" data-action="refresh-dashboard">@Localizer["Refresh"]</button>
        </div>
    </div>
    <div class="header-meta-group">
        <span class="badge badge-info">@Localizer["CurrentHemisphere"]: @(Model.Hemisphere == "North" ? Localizer["North"].Value : Localizer["South"].Value)</span>
        <span class="header-meta">@Localizer["LastUpdated"]: @Model.LastUpdated.ToString("dd/MM/yyyy HH:mm:ss")</span>
    </div>
</div>

<div class="relay-dashboard-grid">
    <main class="relay-main">
        <section class="summary-cards">
            <div class="card card-metric">
                <span class="metric-icon metric-icon-active">🛰️</span>
                <div>
                    <div class="card-title">@Localizer["ActiveRelays"]</div>
                    <div class="card-value" id="activeRelaysCount">@Model.Status.ActiveRelays</div>
                    <div class="card-note">@Localizer["ActiveRelaysNote"]</div>
                </div>
            </div>
            <div class="card card-metric">
                <span class="metric-icon metric-icon-inactive">⛔</span>
                <div>
                    <div class="card-title">@Localizer["InactiveRelays"]</div>
                    <div class="card-value" id="inactiveRelaysCount">@Model.Status.InactiveRelays</div>
                    <div class="card-note">@Localizer["InactiveRelaysNote"]</div>
                </div>
            </div>
            <div class="card card-metric">
                <span class="metric-icon metric-icon-packets">📦</span>
                <div>
                    <div class="card-title">@Localizer["TotalPackets"]</div>
                    <div class="card-value" id="totalPacketsCount">@Model.Status.TotalPacketsProcessed</div>
                    <div class="card-note">@Localizer["TotalPacketsNote"]</div>
                </div>
            </div>
            <div class="card card-metric">
                <span class="metric-icon metric-icon-queue">📊</span>
                <div>
                    <div class="card-title">@Localizer["AvgQueueOccupancy"]</div>
                    <div class="card-value" id="avgQueueCount">@Model.Status.AvgQueueOccupancy.ToString("0.0")% </div>
                    <div class="card-note">@Localizer["QueueOccupancyNote"]</div>
                </div>
            </div>
        </section>

        <section class="relay-charts">
            <div class="chart-column">
                <div class="card chart-card">
                    <div class="card-header chart-header">
                        <h2>@Localizer["QueueHistory"]</h2>
                        <span class="card-subtitle">@Localizer["QueueHistoryDescription"]</span>
                    </div>
                    <div class="chart-container">
                        <canvas id="queueHistoryChart" height="320"></canvas>
                    </div>
                </div>
            </div>
            <div class="card gauge-card status-card">
                <div class="card-header gauge-header">
                    <h2>@Localizer["CurrentAverageOccupancy"]</h2>
                    <span class="card-subtitle">@Localizer["AverageOccupancyDescription"]</span>
                </div>
                <div class="chart-container gauge-container">
                    <canvas id="occupancyGaugeChart" height="320"></canvas>
                </div>
                <div class="gauge-footer">
                    <div class="gauge-value">@Model.Status.AvgQueueOccupancy.ToString("0.0")%</div>
                    <div class="gauge-label">@Localizer["AvgQueueOccupancy"]</div>
                </div>
            </div>
        </section>

        <section class="tables-section">
            <div class="tables-main">
                @await Html.PartialAsync("~/Views/Relay/_RelayRoutesTable.cshtml", Model.Routes)
                @await Html.PartialAsync("~/Views/Relay/_RelayBuffersTable.cshtml", Model.Buffers)
            </div>
        </section>
    </main>

    <aside class="detail-panel relay-side">
        <div class="panel-card detail-card">
            <div class="panel-header panel-header-compact">
                <div>
                    <h2>@Localizer["PacketDetails"]</h2>
                    <span class="panel-subtitle">@Localizer["DetailPanelSubtitle"]</span>
                </div>
            </div>
            <div class="panel-section detail-tabs">
                <button class="tab active" data-detail-tab="info">@Localizer["Information"]</button>
                <button class="tab" data-detail-tab="metadata">@Localizer["Metadata"]</button>
            </div>
            <div class="panel-tab-content">
                <div class="tab-panel tab-info active">
                    <div class="panel-json">
                        <div class="json-label">JSON</div>
                        <pre class="code-block">@System.Text.Json.JsonSerializer.Serialize(Model.Routes.FirstOrDefault() ?? new OrbitNet.Web.Models.ViewModels.RouteDto(), new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
                    </div>
                </div>
                <div class="tab-panel tab-metadata">
                    <div class="meta-grid">
                        @{
                            var route = Model.Routes.FirstOrDefault();
                        }
                        <dt>@Localizer["CurrentHemisphere"]</dt>
                        <dd>@(Model.Hemisphere == "North" ? Localizer["North"].Value : Localizer["South"].Value)</dd>
                        <dt>@Localizer["CurrentPort"]</dt>
                        <dd>@(Model.Hemisphere == "North" ? "5000" : "5001")</dd>
                        <dt>@Localizer["LastUpdated"]</dt>
                        <dd>@Model.LastUpdated.ToString("dd/MM/yyyy HH:mm:ss")</dd>
                        <dt>@Localizer["Origin"]</dt>
                        <dd id="detailRouteOrigin">@route?.FromSatellite ?? "-"</dd>
                        <dt>@Localizer["Destination"]</dt>
                        <dd id="detailRouteDestination">@route?.ToAntenna ?? "-"</dd>
                        <dt>@Localizer["Status"]</dt>
                        <dd id="detailRouteStatus">@route?.Status ?? "-"</dd>
                        <dt>@Localizer["QueueOccupancy"]</dt>
                        <dd id="detailRouteOccupancy">@(route != null ? route.QueueOccupancyPercentage.ToString("0") + "%" : "-")</dd>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel-card events-card">
            <div class="panel-header panel-header-compact">
                <h2>@Localizer["RecentEvents"]</h2>
            </div>
            <div class="panel-section">
                <div class="events-header-row">
                    <span class="panel-subtitle">@Localizer["RecentEvents"]</span>
                    <button class="btn-link btn-sm" type="button" data-action="clear-events">@Localizer["ClearView"]</button>
                </div>
                <div class="event-list">
                    @foreach (var evt in Model.RecentEvents)
                    {
                        <div class="event-item event-@evt.Level.ToLower()">
                            <div class="event-item-header">
                                <span class="status-tag status-@evt.Level.ToLower()">@evt.Level</span>
                                <span class="event-time">@evt.Timestamp.ToString("HH:mm:ss")</span>
                            </div>
                            <div class="event-message">@evt.Message</div>
                        </div>
                    }
                </div>
                <button class="btn-link btn-block" type="button" data-action="view-all-events">@Localizer["ViewAllEvents"]</button>
            </div>
        </div>

        <div class="panel-card quick-actions-card">
            <div class="panel-header panel-header-compact">
                <h2>@Localizer["QuickActions"]</h2>
            </div>
            <div class="panel-side-actions">
                <button class="btn btn-primary btn-large btn-icon" type="button" data-action="resend-all">📡 @Localizer["ResendPendingPackets"]</button>
                <button class="btn btn-secondary btn-large btn-icon" type="button" data-action="test-connectivity">🌐 @Localizer["TestConnectivity"]</button>
                <button class="btn btn-outline btn-large btn-icon" type="button" data-action="export-status-svg">📄 @Localizer["ExportFullStatusSvg"]</button>
            </div>
        </div>
    </aside>
</div>

    <div id="toastContainer" class="toast-container"></div>

    @await Html.PartialAsync("~/Views/Relay/_RelayModals.cshtml")

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const refreshIntervalTop = document.getElementById('refreshIntervalTop');
        const autoRefreshToggleTop = document.getElementById('autoRefreshToggleTop');
        const refreshButton = document.querySelector('[data-action="refresh-dashboard"]');
        const toastContainer = document.getElementById('toastContainer');
        const activeRelaysCount = document.getElementById('activeRelaysCount');
        const inactiveRelaysCount = document.getElementById('inactiveRelaysCount');
        const totalPacketsCount = document.getElementById('totalPacketsCount');
        const avgQueueCount = document.getElementById('avgQueueCount');
        const routesTableBody = document.getElementById('routesTableBody');
        const buffersTableBody = document.getElementById('buffersTableBody');
        const recentEventsList = document.querySelector('.event-list');
        const queueHistoryChartCtx = document.getElementById('queueHistoryChart').getContext('2d');
        const occupancyGaugeCtx = document.getElementById('occupancyGaugeChart').getContext('2d');
        const relayDetailModal = document.getElementById('relayDetailModal');
        const confirmModal = document.getElementById('confirmModal');
        const modalTabs = document.querySelectorAll('.modal-tabs .tab');
        const modalTabInfo = document.getElementById('modalTabInfo');
        const modalTabMetadata = document.getElementById('modalTabMetadata');
        const detailTabs = document.querySelectorAll('.detail-tabs .tab');
        const detailTabInfo = document.querySelector('.tab-info');
        const detailTabMetadata = document.querySelector('.tab-metadata');
        const detailRouteOrigin = document.getElementById('detailRouteOrigin');
        const detailRouteDestination = document.getElementById('detailRouteDestination');
        const detailRouteStatus = document.getElementById('detailRouteStatus');
        const detailRouteOccupancy = document.getElementById('detailRouteOccupancy');
        const gaugeValue = document.querySelector('.gauge-value');

        const logsIndexUrl = '@Url.Action("Index", "Logs")';
        const initialRoutes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Routes));
        const initialBuffers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Buffers));
        const locale = {
            clearBuffer: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ClearBuffer"].Value)),
            exportCsv: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ExportCsv"].Value)),
            refreshNow: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["RefreshNow"].Value)),
            dashboardUpdated: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["DashboardUpdated"].Value)),
            resendPendingPackets: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ResendPendingPackets"].Value)),
            autoRefreshEnabled: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AutoRefreshEnabled"].Value)),
            autoRefreshDisabled: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AutoRefreshDisabled"].Value)),
            copiedToClipboard: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CopiedToClipboard"].Value)),
            clipboardNotSupported: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ClipboardNotSupported"].Value)),
            routeNotFound: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["RouteNotFound"].Value)),
            viewDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ViewDetail"].Value)),
            resend: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Resend"].Value)),
            copy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Copy"].Value)),
            refreshFailed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["RefreshFailed"].Value)),
            resendFailed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ResendFailed"].Value)),
            bufferClearFailed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["BufferClearFailed"].Value)),
            communicationTested: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CommunicationTested"].Value)),
            exportStatusSvg: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ExportFullStatusSvg"].Value)),
            statusExported: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StatusExported"].Value)),
            queueOccupancy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["QueueOccupancy"].Value)),
            used: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Used"].Value)),
            free: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Free"].Value)),
            active: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Active"].Value)),
            inactive: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Inactive"].Value)),
            currentHemisphere: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CurrentHemisphere"].Value)),
            currentPort: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CurrentPort"].Value)),
            lastUpdated: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["LastUpdated"].Value)),
            packetDetailsTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PacketDetails"].Value)),
            packetInformation: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Information"].Value)),
            packetMetadata: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Metadata"].Value)),
            clearView: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ClearView"].Value)),
            viewAllEvents: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ViewAllEvents"].Value)),
            eventViewCleared: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EventViewCleared"].Value)),
            relayStatusExportTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["RelayStatusExportTitle"].Value)),
            hemisphere: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CurrentHemisphere"].Value)),
            processedPackets: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["TotalPackets"].Value)),
            averageOccupancy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AvgQueueOccupancy"].Value)),
            northQueueOccupancy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["NorthHemisphereQueueOccupancy"].Value)),
            southQueueOccupancy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["SouthHemisphereQueueOccupancy"].Value)),
            currentAverageOccupancy: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CurrentAverageOccupancy"].Value)),
            currentAverageOccupancySubtitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AverageOccupancyDescription"].Value)),
            queueHistoryTitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["QueueHistory"].Value)),
            queueHistorySubtitle: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["QueueHistoryDescription"].Value))
        };

        let pollingTimer = null;
        let historyBuffer = [];
        let queueHistoryChart;
        let occupancyGaugeChart;
        let currentRoutes = [];
        let currentBuffers = [];
        let pendingBufferClearId = null;

        function showToast(message, type = 'success') {
            const alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            alert.setAttribute('role', 'status');
            alert.setAttribute('aria-live', 'polite');
            alert.textContent = message;
            toastContainer.appendChild(alert);
            setTimeout(() => alert.remove(), 5000);
        }

        function openModal(modal) {
            if (!modal) return;
            modal.classList.add('open');
            modal.style.display = 'flex';
            modal.setAttribute('aria-hidden', 'false');
        }

        function closeModal(modal) {
            if (!modal) return;
            modal.classList.remove('open');
            modal.style.display = 'none';
            modal.setAttribute('aria-hidden', 'true');
        }

        function getRefreshInterval() {
            const value = refreshIntervalTop?.value;
            return parseInt(value, 10) || 5000;
        }

        function syncRefreshInterval(value) {
            if (refreshIntervalTop) refreshIntervalTop.value = value;
        }

        function syncAutoRefreshToggles(enabled) {
            if (autoRefreshToggleTop) {
                autoRefreshToggleTop.checked = enabled;
            }
        }

        function exportStatusSvg() {
            const status = {
                hemisphere: '@Model.Hemisphere',
                activeRelays: activeRelaysCount.textContent,
                inactiveRelays: inactiveRelaysCount.textContent,
                totalPackets: totalPacketsCount.textContent,
                avgQueue: avgQueueCount.textContent,
                lastUpdated: '@Model.LastUpdated.ToString("dd/MM/yyyy HH:mm:ss")'
            };

            const svg = `<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="720" height="380" viewBox="0 0 720 380">
  <style>
    .title { font: 700 18px Inter, sans-serif; fill: #0f172a; }
    .label { font: 500 13px Inter, sans-serif; fill: #475569; }
    .value { font: 800 22px Inter, sans-serif; fill: #1d4ed8; }
    .badge { font: 600 12px Inter, sans-serif; fill: #ffffff; }
  </style>
  <rect width="100%" height="100%" fill="#f8fafc" rx="24" />
  <text x="32" y="42" class="title">${locale.relayStatusExportTitle}</text>
  <text x="32" y="88" class="label">${locale.hemisphere}</text>
  <text x="32" y="112" class="value">${status.hemisphere}</text>
  <text x="260" y="88" class="label">${locale.active}</text>
  <text x="260" y="112" class="value">${status.activeRelays}</text>
  <text x="460" y="88" class="label">${locale.inactive}</text>
  <text x="460" y="112" class="value">${status.inactiveRelays}</text>
  <text x="32" y="168" class="label">${locale.processedPackets}</text>
  <text x="32" y="194" class="value">${status.totalPackets}</text>
  <text x="260" y="168" class="label">${locale.averageOccupancy}</text>
  <text x="260" y="194" class="value">${status.avgQueue}</text>
  <text x="32" y="270" class="label">${locale.lastUpdated}</text>
  <text x="32" y="294" class="value">${status.lastUpdated}</text>
</svg>`;

            const blob = new Blob([svg], { type: 'image/svg+xml' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'relay-status.svg';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast(locale.statusExported, 'success');
        }

        function getProgressColor(percent) {
            if (percent >= 80) return 'linear-gradient(90deg, var(--danger), #fca5a5)';
            if (percent >= 60) return 'linear-gradient(90deg, var(--warning), #fef08a)';
            if (percent >= 40) return 'linear-gradient(90deg, var(--primary), var(--primary-dark))';
            return 'linear-gradient(90deg, var(--success), #86efac)';
        }

        function setModalTab(tabName) {
            modalTabs.forEach(tab => {
                tab.classList.toggle('active', tab.dataset.tab === tabName);
            });
            modalTabInfo.style.display = tabName === 'info' ? 'block' : 'none';
            modalTabMetadata.style.display = tabName === 'metadata' ? 'block' : 'none';
        }

        function setDetailTab(tabName) {
            detailTabs.forEach(tab => {
                tab.classList.toggle('active', tab.dataset.detailTab === tabName);
            });
            if (detailTabInfo) detailTabInfo.classList.toggle('active', tabName === 'info');
            if (detailTabMetadata) detailTabMetadata.classList.toggle('active', tabName === 'metadata');
        }

        function updateSummaryCards(data) {
            const status = data?.status;
            if (!status) return;

            if (activeRelaysCount) activeRelaysCount.textContent = status.activeRelays ?? 0;
            if (inactiveRelaysCount) inactiveRelaysCount.textContent = status.inactiveRelays ?? 0;
            if (totalPacketsCount) totalPacketsCount.textContent = status.totalPacketsProcessed ?? 0;

            const avgQueue = Number(status.avgQueueOccupancy ?? 0);
            if (avgQueueCount) avgQueueCount.textContent = `${avgQueue.toFixed(1)}%`;
            if (gaugeValue) gaugeValue.textContent = `${avgQueue.toFixed(1)}%`;

            if (queueHistoryChart && occupancyGaugeChart) {
                updateCharts(data);
            }
        }

        function renderRoutes(routes) {
            currentRoutes = Array.isArray(routes) ? routes : [];
            if (!routesTableBody) return;

            routesTableBody.innerHTML = '';
            currentRoutes.forEach(route => {
                const statusText = String(route.status ?? '').toLowerCase().includes('inactive') || String(route.status ?? '').toLowerCase().includes('inactiva') ? locale.inactive : locale.active;
                const statusClass = statusText === locale.inactive ? 'status-inactive' : 'status-active';
                const occupancy = Math.round(Number(route.queueOccupancyPercentage ?? 0));
                const lastSeen = route.lastSeen ? new Date(route.lastSeen).toLocaleString() : '-';

                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${route.fromSatellite ?? ''}</td>
                    <td>${route.toAntenna ?? ''}</td>
                    <td><span class="status-badge ${statusClass}">${statusText}</span></td>
                    <td>${route.packetCount ?? 0}</td>
                    <td>
                        <div class="progress-cell">
                            <div class="progress-track">
                                <div class="progress-bar" style="width:${occupancy}%; background: ${getProgressColor(occupancy)}"></div>
                            </div>
                            <span>${occupancy}%</span>
                        </div>
                    </td>
                    <td>${lastSeen}</td>
                    <td class="action-buttons">
                        <div class="action-buttons-inner">
                            <button class="btn btn-table btn-sm" type="button" data-action="view-details" data-route-id="${route.fromSatellite ?? ''}">${locale.viewDetail}</button>
                            <button class="btn btn-table btn-sm btn-primary" type="button" data-action="resend-route" data-from="${route.fromSatellite ?? ''}" data-to="${route.toAntenna ?? ''}">${locale.resend}</button>
                        </div>
                    </td>`;
                routesTableBody.appendChild(row);
            });
        }

        detailTabs.forEach(tab => {
            tab.addEventListener('click', () => setDetailTab(tab.dataset.detailTab));
        });

        function populateRouteDetail(routeId) {
            const route = currentRoutes.find(item => item.fromSatellite === routeId || item.toAntenna === routeId);
            if (!route) {
                showToast(locale.routeNotFound, 'danger');
                return;
            }

            const detailJson = {
                fromSatellite: route.fromSatellite,
                toAntenna: route.toAntenna,
                status: route.status,
                queueOccupancyPercentage: route.queueOccupancyPercentage,
                lastSeen: route.lastSeen,
                packetData: route.packetData
            };

            const detailPre = relayDetailModal.querySelector('.code-block');
            if (detailPre) {
                detailPre.textContent = JSON.stringify(detailJson, null, 2);
            }

            if (detailRouteOrigin) detailRouteOrigin.textContent = route.fromSatellite;
            if (detailRouteDestination) detailRouteDestination.textContent = route.toAntenna;
            if (detailRouteStatus) detailRouteStatus.textContent = route.status;
            if (detailRouteOccupancy) detailRouteOccupancy.textContent = `${Math.round(route.queueOccupancyPercentage)}%`;

            setModalTab('info');
            openModal(relayDetailModal);
        }

        function renderBuffers(buffers) {
            currentBuffers = buffers;
            buffersTableBody.innerHTML = '';
            buffers.forEach(buffer => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${buffer.bufferId}</td>
                    <td>${buffer.type}</td>
                    <td>${buffer.itemsInQueue}</td>
                    <td>
                        <div class="progress-cell">
                            <div class="progress-track progress-track--large">
                                <div class="progress-bar" style="width:${Math.round(buffer.capacityPercentage)}%; background: ${getProgressColor(buffer.capacityPercentage)}"></div>
                            </div>
                            <span>${Math.round(buffer.capacityPercentage)}%</span>
                        </div>
                    </td>
                    <td>
                        <button class="btn btn-danger btn-sm" type="button" data-action="clear-buffer" data-buffer-id="${buffer.bufferId}">${locale.clearBuffer}</button>
                        <button class="btn btn-outline btn-sm" type="button" data-action="export-buffer" data-buffer-id="${buffer.bufferId}">${locale.exportCsv}</button>
                    </td>
                `;
                buffersTableBody.appendChild(row);
            });
        }

        function renderEvents(events) {
            recentEventsList.innerHTML = '';
            events.forEach(evt => {
                const item = document.createElement('li');
                item.className = `event-item event-${evt.level.toLowerCase()}`;
                item.innerHTML = `<span class="event-time">${new Date(evt.timestamp).toLocaleTimeString()}</span> <strong>${evt.level}</strong> - ${evt.message}`;
                recentEventsList.appendChild(item);
            });
        }

        function updateCharts(data) {
            const timestamp = new Date(data.lastUpdated).toLocaleTimeString();
            const avgQueue = Number(data.status.avgQueueOccupancy ?? 0);
            const northValue = Number(data.status.northQueueOccupancy ?? avgQueue);
            const southValue = Number(data.status.southQueueOccupancy ?? Math.max(0, avgQueue - 10));

            historyBuffer.push({
                time: timestamp,
                north: northValue,
                south: southValue
            });

            if (historyBuffer.length > 20) {
                historyBuffer.shift();
            }

            queueHistoryChart.data.labels = historyBuffer.map(point => point.time);
            queueHistoryChart.data.datasets[0].data = historyBuffer.map(point => point.north);
            queueHistoryChart.data.datasets[1].data = historyBuffer.map(point => point.south);
            queueHistoryChart.update();

            occupancyGaugeChart.data.datasets[0].data = [avgQueue, Math.max(0, 100 - avgQueue)];
            occupancyGaugeChart.update();
        }

        async function fetchRefresh() {
            try {
                const response = await fetch('/Relay/Refresh');
                const payload = await response.json();

                if (payload.status !== 'success') {
                    throw new Error(payload.message || locale.refreshFailed);
                }

                updateSummaryCards(payload.data);
                renderRoutes(payload.data.routes);
                renderBuffers(payload.data.buffers);
                renderEvents(payload.data.recentEvents);
                updateCharts(payload.data);
                showToast(locale.dashboardUpdated, 'success');
            } catch (error) {
                showToast(error.message || locale.refreshFailed, 'danger');
            }
        }

        async function sendForce(requestBody) {
            try {
                const response = await fetch('/Relay/ForceSend', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestBody)
                });
                const payload = await response.json();

                if (!response.ok || payload.status !== 'success') {
                    throw new Error(payload.message || locale.refreshFailed);
                }

                showToast(payload.message, 'success');
                fetchRefresh();
            } catch (error) {
                showToast(error.message || locale.resendFailed, 'danger');
            }
        }

        async function clearBuffer(bufferId) {
            try {
                const response = await fetch(`/Relay/ClearBuffer?bufferId=${encodeURIComponent(bufferId)}`, {
                    method: 'POST'
                });
                const payload = await response.json();

                if (!response.ok || payload.status !== 'success') {
                    throw new Error(payload.message || locale.bufferClearFailed);
                }

                showToast(payload.message, 'success');
                fetchRefresh();
            } catch (error) {
                showToast(error.message || locale.bufferClearFailed, 'danger');
            }
        }

        async function testConnectivity() {
            try {
                const response = await fetch('/Relay/TestConnectivity');
                const payload = await response.json();

                if (!response.ok || payload.status !== 'success') {
                    throw new Error(payload.message || 'No fue posible comprobar la conectividad.');
                }

                showToast(payload.message, payload.connected ? 'success' : 'warning');
            } catch (error) {
                showToast(error.message, 'warning');
            }
        }

        function exportBuffer(bufferId) {
            const url = `/Relay/ExportBuffersCsv?bufferId=${encodeURIComponent(bufferId)}`;
            window.location.href = url;
        }

        function bindActionButtons() {
            document.body.addEventListener('click', event => {
                const button = event.target.closest('button[data-action]');
                if (!button) return;

                const action = button.getAttribute('data-action');
                const bufferId = button.getAttribute('data-buffer-id');
                const fromSatellite = button.getAttribute('data-from');
                const toAntenna = button.getAttribute('data-to');
                const routeId = button.getAttribute('data-route-id');

                if (action === 'resend-route') {
                    sendForce({
                        fromSatellite: fromSatellite,
                        toAntenna: toAntenna,
                        packetData: 'forced relay packet',
                        priority: 1
                    });
                }

                if (action === 'resend-all') {
                    if (currentRoutes.length > 0) {
                        const route = currentRoutes[0];
                        sendForce({
                            fromSatellite: route.fromSatellite,
                            toAntenna: route.toAntenna,
                            packetData: 'forced relay packet',
                            priority: 1
                        });
                        showToast(locale.resendPendingPackets, 'info');
                    }
                }

                if (action === 'test-connectivity') {
                    testConnectivity();
                }

                if (action === 'export-status-svg') {
                    exportStatusSvg();
                }

                if (action === 'clear-buffer' && bufferId) {
                    pendingBufferClearId = bufferId;
                    openModal(confirmModal);
                }

                if (action === 'export-buffer' && bufferId) {
                    exportBuffer(bufferId);
                }

                if (action === 'view-details' && routeId) {
                    populateRouteDetail(routeId);
                }

                if (action === 'refresh-dashboard') {
                    fetchRefresh();
                }

                if (action === 'clear-events') {
                    if (recentEventsList) {
                        recentEventsList.innerHTML = '';
                        showToast(locale.eventViewCleared, 'success');
                    }
                }

                if (action === 'view-all-events') {
                    window.location.href = logsIndexUrl;
                }

                if (action === 'copy-route' && routeId) {
                    if (navigator.clipboard) {
                        navigator.clipboard.writeText(routeId);
                        showToast(locale.copiedToClipboard, 'success');
                    } else {
                        showToast(locale.clipboardNotSupported, 'danger');
                    }
                }

                if (action === 'close-modal') {
                    closeModal(button.closest('.modal'));
                }

                if (action === 'cancel-action') {
                    pendingBufferClearId = null;
                    closeModal(confirmModal);
                }

                if (action === 'confirm-action') {
                    if (pendingBufferClearId) {
                        clearBuffer(pendingBufferClearId);
                        pendingBufferClearId = null;
                    }
                    closeModal(confirmModal);
                }
            });
        }

        function createCharts() {
            const initialGaugeValue = Number(@Model.Status.AvgQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture));
            const initialHistoryTime = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(DateTime.Now.ToString("HH:mm:ss")));

            historyBuffer = [{
                time: initialHistoryTime,
                north: Number(@Model.Status.NorthQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture)),
                south: Number(@Model.Status.SouthQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture))
            }];

            queueHistoryChart = new Chart(queueHistoryChartCtx, {
                type: 'line',
                data: {
                    labels: [initialHistoryTime],
                    datasets: [
                        {
                            label: locale.northQueueOccupancy,
                            borderColor: '#2563eb',
                            backgroundColor: 'rgba(37,99,235,0.15)',
                            tension: 0.3,
                            data: [Number(@Model.Status.NorthQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture))]
                        },
                        {
                            label: locale.southQueueOccupancy,
                            borderColor: '#d97706',
                            backgroundColor: 'rgba(249,115,22,0.15)',
                            tension: 0.3,
                            data: [Number(@Model.Status.SouthQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture))]
                        }
                    ]
                },
                options: {
                    responsive: true,
                    scales: {
                        y: { beginAtZero: true, max: 100 }
                    }
                }
            });

            occupancyGaugeChart = new Chart(occupancyGaugeCtx, {
                type: 'doughnut',
                data: {
                    labels: [locale.used, locale.free],
                    datasets: [{
                        data: [initialGaugeValue, Math.max(0, 100 - initialGaugeValue)],
                        backgroundColor: ['#2563eb', '#e5e7eb'],
                        borderWidth: 0
                    }]
                },
                options: {
                    cutout: '70%',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        function startPolling() {
            const interval = getRefreshInterval();
            if (pollingTimer) {
                clearInterval(pollingTimer);
            }
            pollingTimer = setInterval(fetchRefresh, interval);
        }

        document.addEventListener('DOMContentLoaded', () => {
            bindActionButtons();
            renderRoutes(initialRoutes);
            renderBuffers(initialBuffers);
            createCharts();
            updateSummaryCards({ status: {
                activeRelays: @Model.Status.ActiveRelays,
                inactiveRelays: @Model.Status.InactiveRelays,
                totalPacketsProcessed: @Model.Status.TotalPacketsProcessed,
                avgQueueOccupancy: @Model.Status.AvgQueueOccupancy.ToString(System.Globalization.CultureInfo.InvariantCulture)
            }});

            if (refreshButton) {
                refreshButton.addEventListener('click', fetchRefresh);
            }

            if (autoRefreshToggleTop) {
                autoRefreshToggleTop.addEventListener('change', () => {
                    if (autoRefreshToggleTop.checked) {
                        startPolling();
                        showToast(locale.autoRefreshEnabled, 'success');
                    } else {
                        clearInterval(pollingTimer);
                        showToast(locale.autoRefreshDisabled, 'info');
                    }
                });
            }

            if (refreshIntervalTop) {
                refreshIntervalTop.addEventListener('change', () => {
                    if (autoRefreshToggleTop?.checked) {
                        startPolling();
                    }
                });
            }

            modalTabs.forEach(tab => {
                tab.addEventListener('click', () => setModalTab(tab.dataset.tab));
            });

            if (autoRefreshToggleTop?.checked) {
                startPolling();
            }
        });
    </script>

