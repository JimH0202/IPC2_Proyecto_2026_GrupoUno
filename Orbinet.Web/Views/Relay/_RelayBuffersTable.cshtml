@model List<OrbitNet.Web.Models.ViewModels.BufferDto>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<div class="card table-card">
    <div class="card-header">
            <h2>Buffers</h2>
            <span class="card-subtitle">Capacidad y estado de colas</span>
    </div>
    <div class="tbl-wrap">
        <table class="tbl tbl-relay">
            <thead>
                <tr>
                    <th>ID buffer</th>
                    <th>Tipo</th>
                    <th>Ítems en cola</th>
                    <th>Capacidad (%)</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="buffersTableBody">
                @foreach (var buffer in Model)
                {
                    <tr>
                        <td>@buffer.BufferId</td>
                        <td><span class="badge buffer-type badge-@(buffer.Type.ToLower())">@buffer.Type</span></td>
                        <td>@buffer.ItemsInQueue</td>
                        <td>
                            <div class="progress-cell">
                                <div class="progress-track">
                                    <div class="progress-fill @((buffer.CapacityPercentage >= 80) ? "hi" : (buffer.CapacityPercentage >= 60) ? "mid" : "low")" style="width:@buffer.CapacityPercentage%"></div>
                                </div>
                                <span>@buffer.CapacityPercentage.ToString("0")%</span>
                            </div>
                        </td>
                        <td>
                            <button class="btn btn-danger btn-sm" type="button" data-action="clear-buffer" data-buffer-id="@buffer.BufferId">Vaciar buffer</button>
                            <button class="btn btn-outline btn-sm" type="button" data-action="export-buffer" data-buffer-id="@buffer.BufferId">Exportar CSV</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
