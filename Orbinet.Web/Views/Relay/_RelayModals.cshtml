@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<div class="modal" id="relayDetailModal" tabindex="-1" role="dialog" aria-hidden="true" style="display:none;">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Detalles del paquete</h5>
                <button type="button" class="modal-close" data-action="close-modal">×</button>
            </div>
            <div class="modal-body">
                <div class="modal-tabs">
                    <button class="tab active" data-tab="info">Información</button>
                    <button class="tab" data-tab="metadata">Metadata</button>
                </div>
                <div class="modal-tab-content" id="modalTabInfo">
                    <pre class="code-block">{
    "packetId": "PKT-2024-05-16-102431",
    "from": "SAT-045",
    "to": "ANT-N-03",
    "type": "telemetry",
    "priority": "high",
    "timestamp": "2024-05-16T10:24:31Z",
    "payload": {
        "temperature": 23.4,
        "battery": 87,
        "status": "nominal"
    },
    "checksum": "A1B2C3D4"
}</pre>
                </div>
                <div class="modal-tab-content" id="modalTabMetadata" style="display:none;">
                    <dl class="meta-grid">
                        <dt>@Localizer["RouteId"]</dt><dd>R001</dd>
                        <dt>@Localizer["Priority"]</dt><dd>High</dd>
                        <dt>@Localizer["Origin"]</dt><dd>SAT-045</dd>
                        <dt>@Localizer["Destination"]</dt><dd>ANT-N-03</dd>
                        <dt>@Localizer["LastSeen"]</dt><dd>16/05/2024 10:24</dd>
                    </dl>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" type="button" data-action="close-modal">@Localizer["Close"]</button>
            </div>
        </div>
    </div>
</div>

<div class="modal" id="confirmModal" tabindex="-1" role="dialog" aria-hidden="true" style="display:none;">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localizer["ConfirmAction"]</h5>
                <button type="button" class="modal-close" data-action="close-modal">×</button>
            </div>
            <div class="modal-body">
                <p>@Localizer["ConfirmActionMessage"]</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" type="button" data-action="cancel-action">@Localizer["Cancel"]</button>
                <button class="btn btn-danger" type="button" data-action="confirm-action">@Localizer["Confirm"]</button>
            </div>
        </div>
    </div>
</div>
