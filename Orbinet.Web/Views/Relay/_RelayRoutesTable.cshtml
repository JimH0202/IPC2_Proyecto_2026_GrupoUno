@model List<OrbitNet.Web.Models.ViewModels.RouteDto>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<div class="card table-card">
    <div class="card-header">
            <h2>@Localizer["RoutesHeader"]</h2>
            <span class="card-subtitle">@Localizer["CommunicationRoutesDescription"]</span>
    </div>
    <div class="tbl-wrap">
        <table class="tbl tbl-relay">
            <thead>
                <tr>
                    <th>@Localizer["FromSatellite"]</th>
                    <th>@Localizer["ToAntenna"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Packets"]</th>
                    <th>@Localizer["QueueOccupancy"]</th>
                    <th>@Localizer["LastSeen"]</th>
                    <th>@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="routesTableBody">
                @foreach (var route in Model)
                {
                    <tr>
                        <td>@route.FromSatellite</td>
                        <td>@route.ToAntenna</td>
                        @{
                            var isInactive = route.Status.Contains("inactive", StringComparison.OrdinalIgnoreCase) || route.Status.Contains("inactiva", StringComparison.OrdinalIgnoreCase);
                            var statusText = isInactive ? Localizer["Inactive"].Value : Localizer["Active"].Value;
                            var statusClass = isInactive ? "status-inactive" : "status-active";
                        }
                        <td><span class="status-badge @statusClass">@statusText</span></td>
                        <td>@route.PacketCount</td>
                        <td>
                            <div class="progress-cell">
                                <div class="progress-track">
                                    <div class="progress-bar" style="width:@(Math.Round(route.QueueOccupancyPercentage).ToString(System.Globalization.CultureInfo.InvariantCulture))%; background: @(route.QueueOccupancyPercentage >= 80 ? "linear-gradient(90deg, var(--danger), #fca5a5)" : route.QueueOccupancyPercentage >= 60 ? "linear-gradient(90deg, var(--warning), #fef08a)" : route.QueueOccupancyPercentage >= 40 ? "linear-gradient(90deg, var(--primary), var(--primary-dark))" : "linear-gradient(90deg, var(--success), #86efac)")"></div>
                                </div>
                                <span>@route.QueueOccupancyPercentage.ToString("0")%</span>
                            </div>
                        </td>
                        <td>@route.LastSeen.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="action-buttons">
                            <div class="action-buttons-inner">
                                <button class="btn btn-table btn-sm" type="button" data-action="view-details" data-route-id="@route.FromSatellite">@Localizer["ViewDetail"]</button>
                                <button class="btn btn-table btn-sm btn-primary" type="button" data-action="resend-route" data-from="@route.FromSatellite" data-to="@route.ToAntenna">@Localizer["Resend"]</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
