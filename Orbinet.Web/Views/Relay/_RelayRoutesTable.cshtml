@model List<OrbitNet.Web.Models.ViewModels.RouteDto>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<div class="card table-card">
    <div class="card-header">
            <h2>Rutas de comunicación</h2>
            <span class="card-subtitle">Estado y ocupación de cada enlace</span>
    </div>
    <div class="tbl-wrap">
        <table class="tbl tbl-relay">
            <thead>
                <tr>
                    <th>Desde satélite</th>
                    <th>A antena</th>
                    <th>Estado</th>
                    <th>Paquetes</th>
                    <th>Ocupación cola</th>
                    <th>Último visto</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="routesTableBody">
                @foreach (var route in Model)
                {
                    <tr>
                        <td>@route.FromSatellite</td>
                        <td>@route.ToAntenna</td>
                        <td><span class="status-badge status-@(route.Status.ToLower())">@((route.Status.Contains("active", StringComparison.OrdinalIgnoreCase) || route.Status.Contains("activa", StringComparison.OrdinalIgnoreCase)) ? "🟢 Activa" : (route.Status.Contains("warn", StringComparison.OrdinalIgnoreCase) || route.Status.Contains("intermit", StringComparison.OrdinalIgnoreCase)) ? "🟡 Intermitente" : "🔴 Inactiva")</span></td>
                        <td>@route.PacketCount</td>
                        <td>
                            <div class="progress-cell">
                                <div class="progress-track">
                                    <div class="progress-fill @((route.QueueOccupancyPercentage >= 80) ? "hi" : (route.QueueOccupancyPercentage >= 60) ? "mid" : "low")" style="width:@route.QueueOccupancyPercentage%"></div>
                                </div>
                                <span>@route.QueueOccupancyPercentage.ToString("0")%</span>
                            </div>
                        </td>
                        <td>@route.LastSeen.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="action-buttons">
                            <button class="btn btn-table btn-sm" type="button" data-action="view-details" data-route-id="@route.FromSatellite">👁 Ver detalle</button>
                            <button class="btn btn-table btn-sm btn-primary" type="button" data-action="resend-route" data-from="@route.FromSatellite" data-to="@route.ToAntenna">✈ Reenviar</button>
                            <button class="btn btn-table btn-sm btn-outline" type="button" data-action="copy-route" data-route-id="@route.FromSatellite">📄 Copiar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
