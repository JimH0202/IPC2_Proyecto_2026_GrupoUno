@model OrbitNet.Web.Models.ViewModels.ReportViewModel

<div class="page-header">
    <div>
        <h1>@Model.Title</h1>
        <p class="report-description">@Model.Description</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-secondary">Volver a reportes</a>
        <a asp-controller="Reports" asp-action="ExportSvg" asp-route-report="MemoryLayout" class="btn btn-primary">Exportar SVG</a>
    </div>
</div>

<div class="report-summary">
    <p class="report-description">@Model.Description</p>
    <p class="report-date">Generado: @Model.GeneratedAt.ToString("g")</p>
</div>

<div class="svg-container">
    <div class="svg-wrapper">
        @if (!string.IsNullOrWhiteSpace(Model.SvgContent))
        {
            @Html.Raw(Model.SvgContent)
        }
        else
        {
            <div class="result-box">No hay contenido SVG disponible.</div>
        }
    </div>
</div>
