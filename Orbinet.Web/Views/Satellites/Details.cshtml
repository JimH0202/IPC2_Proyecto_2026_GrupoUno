@model OrbitNet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header-row">
    <div>
        <h1>@Localizer["SatelliteDetail"]: @Model.Id</h1>
        <p>@Localizer["SatelliteDetailDescription"]</p>
    </div>
    <a asp-controller="Satellites" asp-action="Index" class="btn btn-secondary btn-sm">← @Localizer["BackToList"]</a>
</div>

<div class="detail-grid">
    <div class="dcard">
        <div class="dcard-label">@Localizer["Name"]</div>
        <div class="dcard-val">@Model.Name</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Orbit"]</div>
        <div class="dcard-val">@Model.OrbitId</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Type"]</div>
        <div class="dcard-val">@Model.Type</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Status"]</div>
        <div style="margin-top:6px">
            <span class="badge @(Model.IsActive ? "badge-active" : "badge-inactive")">
                @(Model.IsActive ? Localizer["ActiveStatus"] : Localizer["InactiveStatus"])
            </span>
        </div>
    </div>
</div>

<div class="sec">
    <h3>Estadísticas</h3>
    <div class="detail-grid">
        <div class="dcard">
            <div class="dcard-label">@Localizer["MessagesSent"]</div>
            <div class="dcard-val">@Model.MessagesSent</div>
        </div>
        <div class="dcard">
            <div class="dcard-label">@Localizer["MessagesReceived"]</div>
            <div class="dcard-val">@Model.MessagesReceived</div>
        </div>
        <div class="dcard">
            <div class="dcard-label">@Localizer["Resends"]</div>
            <div class="dcard-val">@Model.Resends</div>
        </div>
        <div class="dcard">
            <div class="dcard-label">@Localizer["DiscardedMessages"]</div>
            <div class="dcard-val">@Model.DiscardedMessages</div>
        </div>
        <div class="dcard">
            <div class="dcard-label">@Localizer["Position"]</div>
            <div class="dcard-val">(@Model.X, @Model.Y)</div>
        </div>
        <div class="dcard">
            <div class="dcard-label">@Localizer["LastUpdate"]</div>
            <div class="dcard-val">@Model.LastUpdate.ToString("dd/MM/yyyy HH:mm:ss")</div>
        </div>
    </div>
</div>

<div class="sec">
    <h3>@Localizer["RecentHistory"]</h3>
    @if (Model.RecentHistory != null && Model.RecentHistory.Any())
    {
        <table class="tbl">
            <thead>
                <tr>
                    <th>@Localizer["Timestamp"]</th>
                    <th>@Localizer["Event"]</th>
                    <th>@Localizer["Details"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var log in Model.RecentHistory)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@log.Event</td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="muted">@Localizer["NoRecentHistory"]</div>
    }
</div>
