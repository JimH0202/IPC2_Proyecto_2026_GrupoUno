@model OrbitNet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header">
    <div>
        <h1>Detalle de Satélite</h1>
        <p class="report-description">Información completa del satélite seleccionado y su actividad reciente.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Satellites" asp-action="Index" class="btn btn-primary">Volver a la lista</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al dashboard</a>
    </div>
</div>

<div class="section-card">
    <h3>Resumen del satélite</h3>
    <div class="stats-grid">
        <div class="stat-card">
            <strong>Nombre</strong>
            <p class="stat-value">@Model.Name</p>
        </div>
        <div class="stat-card">
            <strong>Órbita</strong>
            <p class="stat-value">@Model.OrbitId</p>
        </div>
        <div class="stat-card">
            <strong>Tipo</strong>
            <p class="stat-value">@Model.Type</p>
        </div>
        <div class="stat-card">
            <strong>Activo</strong>
            <p class="stat-value">@(Model.IsActive ? "Sí" : "No")</p>
        </div>
    </div>
</div>

<div class="section-card">
    <h3>Actividad</h3>
    <div class="detail-list">
        <div>
            <dt>Posición</dt>
            <dd>(@Model.X, @Model.Y)</dd>
        </div>
        <div>
            <dt>Mensajes enviados</dt>
            <dd>@Model.MessagesSent</dd>
        </div>
        <div>
            <dt>Mensajes recibidos</dt>
            <dd>@Model.MessagesReceived</dd>
        </div>
    </div>
</div>

