@model Orbinet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header">
    <div>
        <h1>Detalle de Satélite</h1>
        <p class="report-description">Información completa del satélite seleccionado y su actividad reciente.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Satellites" asp-action="Index" class="btn btn-primary">Volver a la lista</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al dashboard</a>
    </div>
</div>

<p><strong>Nombre:</strong> @Model.Name</p>
<p><strong>Órbita:</strong> @Model.OrbitId</p>
<p><strong>Tipo:</strong> @Model.Type</p>
<p><strong>Posición:</strong> (@Model.X, @Model.Y)</p>
<p><strong>Activo:</strong> @(Model.IsActive ? "Sí" : "No")</p>
<p><strong>Mensajes enviados:</strong> @Model.MessagesSent</p>
<p><strong>Mensajes recibidos:</strong> @Model.MessagesReceived</p>

