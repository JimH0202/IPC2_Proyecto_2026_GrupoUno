@model OrbitNet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header-row">
    <div>
        <h1>@Localizer["SatelliteDetail"]: @Model.Id</h1>
        <p>@Localizer["SatelliteDetailDescription"]</p>
    </div>
    <a asp-controller="Satellites" asp-action="Index" class="btn btn-secondary btn-sm">← @Localizer["BackToList"]</a>
</div>

<div class="detail-grid">
    <div class="dcard">
        <div class="dcard-label">@Localizer["Name"]</div>
        <div class="dcard-val">@Model.Name</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Orbit"]</div>
        <div class="dcard-val">@Model.OrbitId</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Type"]</div>
        <div class="dcard-val">@Model.Type</div>
    </div>
    <div class="dcard">
        <div class="dcard-label">@Localizer["Status"]</div>
        <div style="margin-top:6px">
            <span class="badge @(Model.IsActive ? "badge-active" : "badge-inactive")">
                @(Model.IsActive ? Localizer["ActiveStatus"] : Localizer["InactiveStatus"])
            </span>
        </div>
    </div>
</div>

<div class="sec">
    <h3>Estadísticas</h3>
    <dl>
        <div class="dfield"><dt>@Localizer["MessagesSent"]</dt><dd>@Model.MessagesSent</dd></div>
        <div class="dfield"><dt>@Localizer["MessagesReceived"]</dt><dd>@Model.MessagesReceived</dd></div>
        <div class="dfield"><dt>@Localizer["Position"]</dt><dd>(@Model.X, @Model.Y)</dd></div>
    </dl>
</div>
