@model List<Orbinet.Web.Models.ViewModels.SatelliteViewModel>

<div class="page-header">
    <div>
        <h1>@Localizer["SatelliteList"]</h1>
        <p class="report-description">@Localizer["SatelliteListDescription"]</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["BackToDashboard"]</a>
    </div>
</div>

<div class="section-card">
    <h3>@Localizer["InventoryOfSatellites"]</h3>
    <table>
    <thead>
        <tr>
            <th>@Localizer["Id"]</th>
            <th>@Localizer["Name"]</th>
            <th>@Localizer["Orbit"]</th>
            <th>@Localizer["Type"]</th>
            <th>@Localizer["Active"]</th>
            <th>@Localizer["MessagesSent"]</th>
            <th>@Localizer["MessagesReceived"]</th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var sat in Model)
    {
        <tr>
            <td>@sat.Id</td>
            <td>@sat.Name</td>
            <td>@sat.OrbitId</td>
            <td>@sat.Type</td>
            <td>@(sat.IsActive ? Localizer["Yes"] : Localizer["No"])</td>
            <td>@sat.MessagesSent</td>
            <td>@sat.MessagesReceived</td>
            <td><a asp-action="Details" asp-route-id="@sat.Id" class="btn btn-primary">@Localizer["ViewDetails"]</a></td>
        </tr>
    }
    </tbody>
</table>
</div>
