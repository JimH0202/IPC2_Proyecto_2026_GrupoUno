@model dynamic
@{
    ViewData["Title"] = Localizer["ErrorTitle"];
}

<div class="page-header">
    <div>
        <h1>@Localizer["ErrorTitle"]</h1>
        <p class="report-description">@Localizer["ErrorDescription"]</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["BackToDashboard"]</a>
    </div>
</div>

<div class="section-card">
    <h3>@Localizer["ErrorDetailsTitle"]</h3>
    <p class="report-description">@Localizer["ErrorContactAdmin"]</p>

    @if (Model?.ShowRequestId == true)
    {
        <div class="detail-list">
            <div>
                <dt>@Localizer["RequestId"]</dt>
                <dd><code>@Model.RequestId</code></dd>
            </div>
        </div>
    }
</div>






                        