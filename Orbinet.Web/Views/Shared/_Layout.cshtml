<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>OrbitNet</title>

    <link rel="stylesheet" href="~/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <h1>OrbitNet</h1>
            </div>
            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="sidebar-link">Dashboard</a>
                <a asp-controller="Upload" asp-action="Index" class="sidebar-link">Carga XML</a>
                <a asp-controller="Simulation" asp-action="Dashboard" class="sidebar-link">Simulación</a>
                <a asp-controller="Matrix" asp-action="Index" class="sidebar-link">Matriz</a>
                <a asp-controller="Satellites" asp-action="Index" class="sidebar-link">Satélites</a>
                <a asp-controller="Reports" asp-action="Index" class="sidebar-link">Reportes</a>
                <a asp-controller="Logs" asp-action="Index" class="sidebar-link">Logs</a>
                <a asp-controller="Configuration" asp-action="Index" class="sidebar-link">Configuración</a>
            </nav>
            <div class="sidebar-footer">
                <a asp-controller="Home" asp-action="Index" class="lang-link">ES</a>
                <span class="sep">|</span>
                <a asp-controller="Home" asp-action="Index" class="lang-link">EN</a>
            </div>
        </aside>

        <div class="content-area">
            <header class="topbar">
                <button class="menu-toggle" aria-label="Toggle menu">☰</button>
                <div class="topbar-title">OrbitNet</div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

</body>
</html>