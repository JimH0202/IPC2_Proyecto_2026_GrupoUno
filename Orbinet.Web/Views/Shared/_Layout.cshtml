@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Localizer["AppTitle"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/site.css" />
    <link rel="stylesheet" href="~/layout.css" />
    <link rel="stylesheet" href="~/sidebar.css" />
    <link rel="stylesheet" href="~/topbar.css" />
    <link rel="stylesheet" href="~/cards.css" />
    <link rel="stylesheet" href="~/buttons.css" />
    <link rel="stylesheet" href="~/tables.css" />
    <link rel="stylesheet" href="~/badges.css" />
    <link rel="stylesheet" href="~/reports.css" />
    <link rel="stylesheet" href="~/upload.css" />
</head>
<body>
    @{
        var activeController = ViewContext.RouteData.Values["controller"]?.ToString();
        var activeAction     = ViewContext.RouteData.Values["action"]?.ToString();
        var isReports        = activeController == "Reports";
    }

    <div class="app-shell">
        <!-- SIDEBAR -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-icon">✕</div>
                <h1>@Localizer["AppTitle"]</h1>
            </div>

            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index"
                   class="sidebar-link @(activeController == "Home" ? "active" : "")">
                    @Localizer["Dashboard"]
                </a>

                <a asp-controller="Upload" asp-action="Index"
                   class="sidebar-link @(activeController == "Upload" ? "active" : "")">
                    @Localizer["XMLUpload"]
                </a>

                <a asp-controller="Simulation" asp-action="Dashboard"
                   class="sidebar-link @(activeController == "Simulation" ? "active" : "")">
                    @Localizer["Simulation"]
                </a>

                <a asp-controller="Matrix" asp-action="Index"
                   class="sidebar-link @(activeController == "Matrix" ? "active" : "")">
                    @Localizer["Matrix"]
                </a>

                <a asp-controller="Satellites" asp-action="Index"
                   class="sidebar-link @(activeController == "Satellites" ? "active" : "")">
                    @Localizer["Satellites"]
                </a>

                <div class="sidebar-menu-group">
                    <button type="button"
                            class="sidebar-link sidebar-menu-toggle @(isReports ? "active open" : "")"
                            id="reportsToggle">
                        @Localizer["Reports"] <span class="menu-arrow">›</span>
                    </button>
                    <div class="sidebar-submenu @(isReports ? "show" : "")">
                        <a asp-controller="Reports" asp-action="Index"
                           class="sidebar-sublink @(isReports && activeAction == "Index" ? "active" : "")">
                            @Localizer["ReportPageTitle"]
                        </a>
                        <a asp-controller="Reports" asp-action="MemoryLayout"
                           class="sidebar-sublink @(isReports && activeAction == "MemoryLayout" ? "active" : "")">
                            @Localizer["ReportCardMemory"]
                        </a>
                        <a asp-controller="Reports" asp-action="Routing"
                           class="sidebar-sublink @(isReports && activeAction == "Routing" ? "active" : "")">
                            @Localizer["ReportCardRouting"]
                        </a>
                        <a asp-controller="Reports" asp-action="Buffers"
                           class="sidebar-sublink @(isReports && activeAction == "Buffers" ? "active" : "")">
                            @Localizer["ReportCardBuffers"]
                        </a>
                    </div>
                </div>

                <a asp-controller="Logs" asp-action="Index"
                   class="sidebar-link @(activeController == "Logs" ? "active" : "")">
                    @Localizer["Logs"]
                </a>

                <a asp-controller="Configuration" asp-action="Index"
                   class="sidebar-link @(activeController == "Configuration" ? "active" : "")">
                    @Localizer["Configuration"]
                </a>
            </nav>

            <div class="sidebar-footer">
                <a asp-controller="Home" asp-action="SetLanguage"
                   asp-route-culture="es"
                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                   class="lang-link">ES</a>
                <span class="sep">|</span>
                <a asp-controller="Home" asp-action="SetLanguage"
                   asp-route-culture="en"
                   asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                   class="lang-link">EN</a>
            </div>
        </aside>

        <!-- CONTENT AREA -->
        <div class="content-area">
            <header class="topbar">
                <div class="topbar-left">
                    <button class="menu-toggle" id="menu-toggle">☰</button>
                    <span class="topbar-title">@Localizer["AppTitle"]</span>
                </div>
                <div class="topbar-right">
                    <a asp-controller="Home" asp-action="SetLanguage"
                       asp-route-culture="es"
                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                       class="topbar-lang-btn">ES</a>
                    <span class="sep">|</span>
                    <a asp-controller="Home" asp-action="SetLanguage"
                       asp-route-culture="en"
                       asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                       class="topbar-lang-btn">EN</a>
                </div>
            </header>

            <main class="page-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        document.getElementById('menu-toggle').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('collapsed');
        });

        document.getElementById('reportsToggle')?.addEventListener('click', function () {
            var submenu = this.nextElementSibling;
            submenu.classList.toggle('show');
            this.classList.toggle('open');
        });
    </script>
</body>
</html>
