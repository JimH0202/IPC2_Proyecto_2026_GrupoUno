<div class="page-header">
    <h1>@Localizer["SimulationDashboardTitle"]</h1>
    <p>@Localizer["SimulationDescription"]</p>
</div>

<div class="metrics">
    <div class="mcard">
        <div class="mtitle">@Localizer["CurrentTick"]</div>
        <div class="mval blue">@Model.CurrentTick</div>
    </div>
    <div class="mcard">
        <div class="mtitle">@Localizer["ActiveSatellites"]</div>
        <div class="mval green">@Model.ActiveSatellites</div>
    </div>
    <div class="mcard">
        <div class="mtitle">@Localizer["PendingMessages"]</div>
        <div class="mval orange">@Model.PendingMessages</div>
    </div>
    <div class="mcard">
        <div class="mtitle">Estado</div>
        <div style="margin-top:6px">
            <span class="badge badge-sim @(Model.IsSimulationRunning ? "" : "badge-inactive")">
                @(Model.IsSimulationRunning ? Localizer["Active"] : Localizer["Stopped"])
            </span>
        </div>
    </div>
</div>

<div class="sec">
    <h3>@Localizer["SimulationControls"]</h3>
    <div class="sim-controls">
        <form asp-action="TickResult" method="post" style="display:inline">
            <button type="submit" class="btn btn-secondary">@Localizer["ExecuteTick"]</button>
        </form>
        <form asp-action="ExecuteTicks" method="post" style="display:inline">
            <input type="hidden" name="count" value="10" />
            <button type="submit" class="btn btn-secondary">@Localizer["Execute10Ticks"]</button>
        </form>
        <form asp-action="ExecuteTicks" method="post" style="display:inline">
            <input type="hidden" name="count" value="100" />
            <button type="submit" class="btn btn-secondary">@Localizer["Execute100Ticks"]</button>
        </form>
        <form asp-action="StopSimulation" method="post" style="display:inline">
            <button type="submit" class="btn btn-danger">@Localizer["StopSimulation"]</button>
        </form>
    </div>
</div>

<div class="sec">
    <h3>@Localizer["ActiveSatellites"]</h3>
    <table class="tbl">
        <thead>
            <tr>
                <th>@Localizer["Id"]</th>
                <th>@Localizer["Name"]</th>
                <th>@Localizer["Orbit"]</th>
                <th>@Localizer["Active"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sat in Model.Satellites)
            {
                <tr>
                    <td>@sat.Id</td>
                    <td>@sat.Name</td>
                    <td>@sat.OrbitId</td>
                    <td><span class="badge @(sat.IsActive ? "badge-active" : "badge-inactive")">@(sat.IsActive ? Localizer["Yes"] : Localizer["No"])</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>
