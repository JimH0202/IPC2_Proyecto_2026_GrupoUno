<div class="page-header">
    <div>
        <h1>Dashboard de Simulación</h1>
        <p class="report-description">Supervisa ticks, satélites activos y mensajes en cola para la simulación.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al dashboard</a>
    </div>
</div>

<div class="simulation-metrics">
    <div class="metric-box">
        <span class="metric-label">Tick actual:</span>
        <span class="metric-value">@Model.CurrentTick</span>
    </div>
    <div class="metric-box">
        <span class="metric-label">Satélites activos:</span>
        <span class="metric-value">@Model.ActiveSatellites</span>
    </div>
    <div class="metric-box">
        <span class="metric-label">Mensajes pendientes:</span>
        <span class="metric-value">@Model.PendingMessages</span>
    </div>
    <div class="metric-box">
        <span class="metric-label">Mensajes procesados:</span>
        <span class="metric-value">@Model.ProcessedMessages</span>
    </div>
</div>

<h3>Satélites activos</h3>
<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>orbita</th>
            <th>Activo</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var sat in Model.Satellites)
    {
        <tr>
            <td>@sat.Id</td>
            <td>@sat.Name</td>
            <td>@sat.OrbitId</td>
            <td>@(sat.IsActive ? "Si" : "No")</td>
        </tr>
    }
    </tbody>
</table>

<div class="simulation-controls">
    <form asp-action="TickResult" method="post" style="display:inline;">
        <button type="submit" class="btn btn-primary">Ejecutar siguiente tick</button>
    </form>
</div>
