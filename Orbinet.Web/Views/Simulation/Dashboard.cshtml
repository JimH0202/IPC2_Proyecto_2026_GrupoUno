@model OrbitNet.Web.Models.ViewModels.SimulationViewModel

<h1>Dashboard de Simulaciˇn</h1>
<p>Tick actual: @Model.CurrentTick</p>
<p>SatÚlites activos: @Model.ActiveSatellites</p>
<p>Mensajes pendientes: @Model.PendingMessages</p>
<p>Mensajes procesados: @Model.ProcessedMessages</p>
<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Ërbita</th>
            <th>Activo</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var sat in Model.Satellites)
    {
        <tr>
            <td>@sat.Id</td>
            <td>@sat.Name</td>
            <td>@sat.OrbitId</td>
            <td>@(sat.IsActive ? "SÝ" : "No")</td>
        </tr>
    }
    </tbody>
</table>
