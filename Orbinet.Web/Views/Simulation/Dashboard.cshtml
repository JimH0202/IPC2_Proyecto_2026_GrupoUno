<div class="page-header">
    <div>
        <h1>Dashboard de Simulación</h1>
        <p class="report-description">Supervisa ticks, satélites activos y mensajes en cola para la simulación.</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <strong>Tick Actual</strong>
        <p class="stat-value">@Model.CurrentTick</p>
    </div>
    <div class="stat-card">
        <strong>Satélites Activos</strong>
        <p class="stat-value">@Model.ActiveSatellites</p>
    </div>
    <div class="stat-card">
        <strong>Mensajes Pendientes</strong>
        <p class="stat-value">@Model.PendingMessages</p>
    </div>
    <div class="stat-card">
        <strong>Mensajes Procesados</strong>
        <p class="stat-value">@Model.ProcessedMessages</p>
    </div>
</div>

<div class="simulation-controls" style="display:flex;gap:10px;margin-top:18px;">
    <form asp-action="TickResult" method="post">
        <button type="submit" class="btn btn-primary">Ejecutar 1 Tick</button>
    </form>

    <form asp-action="ExecuteTicks" method="post">
        <input type="hidden" name="count" value="10" />
        <button type="submit" class="btn btn-primary">Ejecutar 10 Ticks</button>
    </form>

    <form asp-action="ExecuteTicks" method="post">
        <input type="hidden" name="count" value="100" />
        <button type="submit" class="btn btn-primary">Ejecutar 100 Ticks</button>
    </form>

    <form asp-action="StopSimulation" method="post">
        <button type="submit" class="btn btn-secondary">Detener Simulación</button>
    </form>
</div>

<h3 style="margin-top:24px;">Satélites activos</h3>
<div class="tick-result-box">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Órbita</th>
                <th>Activo</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var sat in Model.Satellites)
        {
            <tr>
                <td>@sat.Id</td>
                <td>@sat.Name</td>
                <td>@sat.OrbitId</td>
                <td>@(sat.IsActive ? "Sí" : "No")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
