@model OrbitNet.Web.Models.ViewModels.SimulationViewModel

<div class="page-header">
    <div>
        <h1>@Localizer["TickResultTitle"]</h1>
        <p class="report-description">@Localizer["TickResultDescription"]</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Simulation" asp-action="Dashboard" class="btn btn-primary">@Localizer["BackToDashboard"]</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["Home"]</a>
    </div>
</div>

<div class="sec">
    <div class="metrics" role="region" aria-label="Simulation metrics">
        <div class="mcard">
            <div class="mtitle">@Localizer["TickResultCurrentTick"]</div>
            <div class="mval blue">@Model.CurrentTick</div>
            <div class="msub">@Localizer["TickResultSimulation"]: @(Model.IsSimulationRunning ? Localizer["Active"] : Localizer["Stopped"])</div>
        </div>

        <div class="mcard">
            <div class="mtitle">@Localizer["TickResultProcessedMessages"]</div>
            <div class="mval green">@Model.ProcessedMessages</div>
            <div class="msub">@Localizer["Messages processed in recent ticks"]</div>
        </div>

        <div class="mcard">
            <div class="mtitle">@Localizer["TickResultActiveSatellites"]</div>
            <div class="mval orange">@Model.ActiveSatellites</div>
            <div class="msub">@Localizer["Satellites currently active"]</div>
        </div>

        <div class="mcard">
            <div class="mtitle">@Localizer["TickResultPendingMessages"]</div>
            <div class="mval red">@Model.PendingMessages</div>
            <div class="msub">@Localizer["Messages waiting in queue"]</div>
        </div>
    </div>

    <div class="stats2">
        <div class="scard">
            <div class="slabel">@Localizer["Controls"]</div>
            <div>
                <form asp-controller="Simulation" asp-action="TickResult" method="post" style="display:inline">
                    <button type="submit" class="btn btn-secondary">@Localizer["ExecuteTick"]</button>
                </form>
                <form asp-controller="Simulation" asp-action="ExecuteTicks" method="post" style="display:inline; margin-left:8px">
                    <input type="hidden" name="count" value="10" />
                    <button type="submit" class="btn btn-secondary">@Localizer["Execute10Ticks"]</button>
                </form>
                <form asp-controller="Simulation" asp-action="ExecuteTicks" method="post" style="display:inline; margin-left:8px">
                    <input type="hidden" name="count" value="100" />
                    <button type="submit" class="btn btn-secondary">@Localizer["Execute100Ticks"]</button>
                </form>
            </div>
        </div>

        <div class="scard">
            <div class="slabel">@Localizer["Simulation Status"]</div>
            <div class="sval primary">@(Model.IsSimulationRunning ? Localizer["Active"] : Localizer["Stopped"])</div>
            <div class="msub">@Localizer["TickResultCurrentTick"]: @Model.CurrentTick</div>
        </div>

        <div class="scard">
            <div class="slabel">@Localizer["Processed"]</div>
            <div class="sval">@Model.ProcessedMessages</div>
            <div class="msub">@Localizer["Total messages processed"]</div>
        </div>
    </div>

    <h3>@Localizer["TickResultSatellitesStatusTitle"]</h3>
    <div class="detail-grid">
        @foreach (var sat in Model.Satellites)
        {
            <div class="dcard">
                <div class="dcard-label">@Localizer["Name"]</div>
                <div class="dcard-val">@sat.Name (@sat.Id)</div>
                <dl class="dfield">
                    <dt>@Localizer["Orbit"]</dt>
                    <dd>@sat.OrbitId</dd>
                </dl>
                <dl class="dfield">
                    <dt>@Localizer["Status"]</dt>
                    <dd>
                        @if (sat.IsActive)
                        {
                            <span class="badge badge-success" style="color:var(--success); font-weight:700;">@Localizer["ActiveStatus"]</span>
                        }
                        else
                        {
                            <span class="badge" style="color:var(--muted);">@Localizer["InactiveStatus"]</span>
                        }
                    </dd>
                </dl>
            </div>
        }
    </div>
</div>

 