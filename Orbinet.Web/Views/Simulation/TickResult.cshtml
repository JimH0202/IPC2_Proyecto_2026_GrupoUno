@model OrbitNet.Web.Models.ViewModels.SimulationViewModel

<div class="page-header">
    <div>
        <h1>@Localizer["TickResultTitle"]</h1>
        <p class="report-description">@Localizer["TickResultDescription"]</p>
    </div>
    <div class="page-actions">
        <a asp-controller="Simulation" asp-action="Dashboard" class="btn btn-primary">@Localizer["BackToDashboard"]</a>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">@Localizer["Home"]</a>
    </div>
</div>

<div class="section-card">
    <div class="tick-result-box">
        <div class="result-item">
            <strong>@Localizer["TickResultCurrentTick"]</strong> @Model.CurrentTick
        </div>
        <div class="result-item">
            <strong>@Localizer["TickResultProcessedMessages"]</strong> <span class="highlight">@Model.ProcessedMessages</span>
        </div>
        <div class="result-item">
            <strong>@Localizer["TickResultActiveSatellites"]</strong> @Model.ActiveSatellites
        </div>
        <div class="result-item">
            <strong>@Localizer["TickResultPendingMessages"]</strong> @Model.PendingMessages
        </div>
        <div class="result-item">
            <strong>@Localizer["TickResultSimulation"]</strong> @(Model.IsSimulationRunning ? Localizer["Active"] : Localizer["Stopped"])
        </div>
    </div>

    <h3 style="margin-top: 28px;">@Localizer["TickResultSatellitesStatusTitle"]</h3>
    <table>
    <thead>
        <tr>
            <th>@Localizer["Id"]</th>
            <th>@Localizer["Name"]</th>
            <th>@Localizer["Orbit"]</th>
            <th>@Localizer["Status"]</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var sat in Model.Satellites)
    {
        <tr>
            <td>@sat.Id</td>
            <td>@sat.Name</td>
            <td>@sat.OrbitId</td>
            <td>@(sat.IsActive ? Localizer["ActiveStatus"] : Localizer["InactiveStatus"])</td>
        </tr>
    }
    </tbody>
</table>

