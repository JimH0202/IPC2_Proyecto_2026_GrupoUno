@model List<OrbitNet.Web.Models.ViewModels.RouteDto>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<OrbitNet.Web.Controllers.SharedResource> Localizer

<div class="table-card">
    <div class="card-header">
        <h2 style="margin:0;font-size:16px">@Localizer["RoutesHeader"]</h2>
        <small style="color:var(--muted)">@Localizer["CommunicationRoutesDescription"]</small>
    </div>

    <div style="overflow-x:auto">
        <table class="table">
            <thead>
                <tr>
                    <th>@Localizer["FromSatellite"]</th>
                    <th>@Localizer["ToAntenna"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["Resends"]</th>
                    <th>@Localizer["QueueOccupancy"]</th>
                    <th>@Localizer["LastSeen"]</th>
                    <th>@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody id="routesTableBody">
                @foreach (var route in Model)
                {
                    <tr>
                        <td>@route.FromSatellite</td>
                        <td>@route.ToAntenna</td>
                        <td><span class="badge badge-@(route.Status.ToLower())">@route.Status</span></td>
                        <td>@route.PacketCount</td>
                        <td>
                            <div class="progress-cell">
                                <div class="progress-bar" style="width:@route.QueueOccupancyPercentage%"></div>
                                <span>@route.QueueOccupancyPercentage.ToString("0")%</span>
                            </div>
                        </td>
                        <td>@route.LastSeen.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <button class="btn btn-secondary btn-sm" type="button" data-action="view-details" data-route-id="@route.FromSatellite">@Localizer["ViewDetail"]</button>
                            <button class="btn btn-primary btn-sm" type="button" data-action="resend-route" data-from="@route.FromSatellite" data-to="@route.ToAntenna">@Localizer["Resend"]</button>
                            <button class="btn btn-outline-custom btn-sm" type="button" data-action="copy-route" data-route-id="@route.FromSatellite">@Localizer["Copy"]</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
