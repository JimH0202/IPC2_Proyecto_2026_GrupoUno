@{
    ViewData["Title"] = Localizer["ReportPageTitle"];
}

<div class="page-header">
    <h1>@Localizer["ReportPageTitle"]</h1>
    <p>@Localizer["ReportsPageDescription"]</p>
</div>

<div class="reports-grid">
    <div class="rep-card">
        <h3>@Localizer["ReportCardMemory"]</h3>
        <p>@Localizer["ReportCardMemoryDescription"]</p>
        <a asp-controller="Reports" asp-action="MemoryLayout" class="rep-link">@Localizer["ViewReport"] →</a>
    </div>
    <div class="rep-card">
        <h3>@Localizer["ReportCardMatrix"]</h3>
        <p>@Localizer["ReportCardMatrixDescription"]</p>
        <a asp-controller="Matrix" asp-action="Index" class="rep-link">@Localizer["ViewReport"] →</a>
    </div>
    <div class="rep-card">
        <h3>@Localizer["ReportCardBuffers"]</h3>
        <p>@Localizer["ReportCardBuffersDescription"]</p>
        <a asp-controller="Reports" asp-action="Buffers" class="rep-link">@Localizer["ViewReport"] →</a>
    </div>
    <div class="rep-card">
        <h3>@Localizer["ReportCardRouting"]</h3>
        <p>@Localizer["ReportCardRoutingDescription"]</p>
        <a asp-controller="Reports" asp-action="Routing" class="rep-link">@Localizer["ViewReport"] →</a>
    </div>
</div>
