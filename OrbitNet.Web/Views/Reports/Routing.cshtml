@model OrbitNet.Web.Models.ViewModels.ReportViewModel
@{
    var reportKey = ViewContext.RouteData.Values["action"]?.ToString() ?? "Routing";
}

<div class="page-header-row">
    <div>
        <h1>@Model.Title</h1>
        <p>@Model.Description</p>
    </div>
    <a asp-controller="Reports" asp-action="ExportSvg" asp-route-report="@reportKey"
       class="btn btn-primary btn-sm">@Localizer["DownloadSvg"]</a>
</div>

<div class="report-wrap">
    <div class="report-svg-area" style="min-height:240px">
        @if (!string.IsNullOrWhiteSpace(Model.SvgContent))
        {
            @Html.Raw(Model.SvgContent)
        }
        else
        {
            <span style="color:var(--muted);font-size:13px">@Localizer["NoSvgContent"]</span>
        }
    </div>
</div>
