@model OrbitNet.Web.Models.ViewModels.SatelliteViewModel

<div class="page-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap">
    <div>
        <h1>@Localizer["SatelliteDetail"]: @Model.Id</h1>
        <p>@Localizer["SatelliteDetailDescription"]</p>
    </div>
    <a asp-controller="Satellites" asp-action="Index" class="btn btn-secondary btn-sm">← @Localizer["BackToList"]</a>
</div>

<div class="reports-grid">
    <div class="stat-card">
        <strong>@Localizer["Name"]</strong>
        <div class="stat-value">@Model.Name</div>
    </div>
    <div class="stat-card">
        <strong>@Localizer["Orbit"]</strong>
        <div class="stat-value">@Model.OrbitId</div>
    </div>
    <div class="stat-card">
        <strong>@Localizer["Type"]</strong>
        <div class="stat-value">@Model.Type</div>
    </div>
    <div class="stat-card">
        <strong>@Localizer["Status"]</strong>
        <div style="margin-top:8px">
            <span class="@(Model.IsActive ? "badge-active" : "badge-inactive")">
                @(Model.IsActive ? Localizer["ActiveStatus"] : Localizer["InactiveStatus"])
            </span>
        </div>
    </div>
</div>

<div class="table-card" style="margin-top:24px;padding:20px">
    <h3 style="margin-top:0">@Localizer["Statistics"]</h3>
    <div class="reports-grid" style="margin-top:16px">
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["MessagesSent"]</strong>
            <div class="stat-value">@Model.MessagesSent</div>
        </div>
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["MessagesReceived"]</strong>
            <div class="stat-value">@Model.MessagesReceived</div>
        </div>
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["Resends"]</strong>
            <div class="stat-value">@Model.Resends</div>
        </div>
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["DiscardedMessages"]</strong>
            <div class="stat-value">@Model.DiscardedMessages</div>
        </div>
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["Position"]</strong>
            <div class="stat-value">(@Model.X, @Model.Y)</div>
        </div>
        <div class="stat-card" style="padding:16px">
            <strong>@Localizer["LastUpdate"]</strong>
            <div class="stat-value">@Model.LastUpdate.ToString("dd/MM/yyyy HH:mm:ss")</div>
        </div>
    </div>
</div>

<div class="table-card" style="margin-top:24px;padding:20px">
    <h3 style="margin-top:0">@Localizer["RecentHistory"]</h3>
    @if (Model.RecentHistory != null && Model.RecentHistory.Any())
    {
        <table class="table">
            <thead>
                <tr>
                    <th>@Localizer["Timestamp"]</th>
                    <th>@Localizer["Event"]</th>
                    <th>@Localizer["Details"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var log in Model.RecentHistory)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                        <td>@log.Event</td>
                        <td>@log.Details</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div style="color:var(--muted)">@Localizer["NoRecentHistory"]</div>
    }
</div>
